        "notebook_path": "/Workspace/Users/deshpande.ajay.us@gmail.com/churn-ops/notebooks/03_training_and_tracking"
      },
      "job_cluster_key": "churn_job_cluster",
      "timeout_seconds": 3600,
      "max_retries": 1
    },
    {
      "task_key": "04_model_registry",
