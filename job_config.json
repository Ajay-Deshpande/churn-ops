      },
      "job_cluster_key": "churn_job_cluster",
      "timeout_seconds": 1800,
      "max_retries": 1
    },
    {
      "task_key": "02_feature_engineering",
      "depends_on": [{ "task_key": "01_data_ingestion" }],
      "notebook_task": {
